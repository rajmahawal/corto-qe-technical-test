{
  "name": "corto-qe-technical-test",
  "version": "1.0.0",
  "description": "CORTO Quality Engineering technical test covering UI and API automation using Playwright and TypeScript.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <26"
  },
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui-chromium",
    "test:ui:sequential": "playwright test --project=ui-chromium --workers=1",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "keywords": [
    "playwright",
    "typescript",
    "quality-engineering",
    "ui-automation",
    "api-automation"
  ],
  "author": "Raj Mahawal",
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  }
}
