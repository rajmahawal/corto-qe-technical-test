{
  "name": "corto-qe-technical-test",
  "version": "1.0.0",
  "description": "CORTO Quality Engineering technical test covering UI and API automation using Playwright and TypeScript.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test tests/api",
    "test:ui": "playwright test tests/ui --workers=1",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "quality-engineering",
    "ui-automation",
    "api-automation"
  ],
  "author": "Raj Mahawal",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "typescript": "^5.9.3"
  }
}